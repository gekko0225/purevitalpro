---
import BaseLayout from "../layouts/BaseLayout.astro";

const phone = "+573128460832"; // Cambia por tu número real con código de país
const message = encodeURIComponent(
  "Hola, vi la landing del Reto Reset 21. ¿Cuánto vale y cómo lo adquiero?"
);
const whatsappUrl = `https://wa.me/${phone}?text=${message}`;
---

<BaseLayout
  title="Reto Reset 21 | Pure Vital Pro"
  description="Transforma tu cuerpo en 21 días con acompañamiento, hábitos saludables, entrenamiento y soporte personalizado."
>
  <main class="landing">
    <section class="hero">
      <div class="hero-overlay"></div>

      <div class="container hero-content">
        <p class="eyebrow">PURE VITAL PRO PRESENTA</p>

        <h1>
          RETO <span>RESET</span>
          <strong>21</strong>
        </h1>

        <p class="hero-text">
          Si llegaste hasta aquí es porque estás lista/o para un cambio real.
          Reinicia tu cuerpo, mejora tus hábitos y recupera tu energía.
        </p>

        <div class="hero-actions">
          <a
            href={whatsappUrl}
            class="btn-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            ¿CUÁNTO VALE?
          </a>

          <span class="limited">🔥 Cupos limitados</span>
        </div>
      </div>
    </section>

    <div class="countdown" data-countdown="2026-05-07T00:00:00">
  <p class="countdown-label">⏳ Iniciamos el 7 de mayo</p>

  <div class="countdown-grid">
    <div>
      <strong data-days>00</strong>
      <span>Días</span>
    </div>

    <div>
      <strong data-hours>00</strong>
      <span>Horas</span>
    </div>

    <div>
      <strong data-minutes>00</strong>
      <span>Min</span>
    </div>

    <div>
      <strong data-seconds>00</strong>
      <span>Seg</span>
    </div>
  </div>
</div>

    <section class="benefits">
      <div class="container">
        <p class="section-kicker">Tu transformación empieza aquí</p>
        <h2>¿Qué lograrás?</h2>

        <div class="grid cards">
          <article>
            <span>⚡</span>
            <h3>Más energía</h3>
            <p>Recupera vitalidad y claridad mental.</p>
          </article>

          <article>
            <span>💧</span>
            <h3>Menos inflamación</h3>
            <p>Apoyo para sentirte más ligera/o.</p>
          </article>

          <article>
            <span>🔥</span>
            <h3>Mejor composición corporal</h3>
            <p>Ayuda para bajar peso y mejorar hábitos.</p>
          </article>

          <article>
            <span>🧠</span>
            <h3>Disciplina real</h3>
            <p>Rutinas sostenibles para mantener resultados.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="includes">
      <div class="container">
        <p class="section-kicker">Todo lo que recibes</p>
        <h2>¿Qué incluye el reto?</h2>

        <div class="includes-grid">
          <article class="include-card">
            <span class="include-icon">📋</span>
            <h3>Tracker de hábitos</h3>
            <p>Registro diario para medir tu avance.</p>
          </article>

          <article class="include-card">
            <span class="include-icon">🥗</span>
            <h3>Comidas e hidratación</h3>
            <p>Guía práctica para organizarte mejor.</p>
          </article>

          <article class="include-card">
            <span class="include-icon">🍽️</span>
            <h3>Recetas saludables</h3>
            <p>Ideas simples para comer mejor.</p>
          </article>

          <article class="include-card">
            <span class="include-icon">💊</span>
            <h3>Suplementación guiada</h3>
            <p>Orientación para usar el paquete del reto.</p>
          </article>

          <article class="include-card">
            <span class="include-icon">🏋️</span>
            <h3>Ejercicios y rutinas</h3>
            <p>Movimiento adaptado al proceso.</p>
          </article>

          <article class="include-card">
            <span class="include-icon">🎥</span>
            <h3>Live de entrenamiento</h3>
            <p>Sesión semanal en vivo.</p>
          </article>

          <article class="include-card">
            <span class="include-icon">📈</span>
            <h3>Live de seguimiento</h3>
            <p>Revisión semanal para mantener enfoque.</p>
          </article>

          <article class="include-card">
            <span class="include-icon">🏅</span>
            <h3>Certificado digital</h3>
            <p>Reconocimiento al completar el reto.</p>
          </article>

          <article class="include-card">
            <span class="include-icon">👥</span>
            <h3>Grupo privado</h3>
            <p>Comunidad exclusiva en Facebook y WhatsApp.</p>
          </article>

          <article class="include-card">
            <span class="include-icon">🎁</span>
            <h3>Bonos extras</h3>
            <p>Material adicional para potenciar tu avance.</p>
          </article>

          <article class="include-card">
            <span class="include-icon">🤖</span>
            <h3>Reset 21 IA</h3>
            <p>Apoyo personalizado 24/7.</p>
          </article>

          <article class="include-card">
            <span class="include-icon">📦</span>
            <h3>Paquete de suplementos</h3>
            <p>Productos incluidos para acompañar el reto.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="testimonials">
      <div class="container">
        <p class="section-kicker">Experiencias del reto</p>
        <h2>Historias reales</h2>

        <div class="grid reviews">
          <article>
            <img
              src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=300&auto=format&fit=crop"
              alt="Testimonio de participante del reto"
              loading="lazy"
            />
            <p>“Volví a sentirme con energía y enfoque.”</p>
            <strong>María G.</strong>
          </article>

          <article>
            <img
              src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=300&auto=format&fit=crop"
              alt="Testimonio de participante del reto"
              loading="lazy"
            />
            <p>“Lo mejor fue la guía diaria y el grupo.”</p>
            <strong>Carlos R.</strong>
          </article>

          <article>
            <img
              src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=300&auto=format&fit=crop"
              alt="Testimonio de participante del reto"
              loading="lazy"
            />
            <p>“Me ayudó a retomar hábitos saludables.”</p>
            <strong>Ana L.</strong>
          </article>
        </div>
      </div>
    </section>

    <section class="cta">
      <div class="container">
        <h2>¿Listos para iniciar el reto?</h2>

        <p>
          Escríbeme ahora y te explico precio, acceso y cómo empezar hoy.
        </p>

        <a
          href={whatsappUrl}
          class="btn-primary big"
          target="_blank"
          rel="noopener noreferrer"
        >
          ¿CÓMO LO ADQUIERO?
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(body) {
    margin: 0;
    font-family: Inter, system-ui, sans-serif;
    background: #020505;
    color: #fff;
  }

  .container {
    width: min(1180px, calc(100% - 2rem));
    margin: auto;
  }

  .landing {
    overflow: hidden;
    background:
      radial-gradient(circle at top left, rgba(0, 255, 230, 0.18), transparent 35rem),
      radial-gradient(circle at 80% 10%, rgba(0, 255, 230, 0.08), transparent 25rem),
      linear-gradient(180deg, #020505, #071010, #020505);
  }

  section {
    padding: 5rem 0;
  }

  .hero {
    min-height: 100vh;
    display: grid;
    place-items: center;
    text-align: center;
    position: relative;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 70px 70px;
    mask-image: radial-gradient(circle, black, transparent 75%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
  }

  .eyebrow,
  .section-kicker {
    color: #2cf7e7;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-size: 0.85rem;
  }

  .eyebrow {
    margin-bottom: 1rem;
  }

  .section-kicker {
    text-align: center;
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: clamp(4rem, 14vw, 10rem);
    line-height: 0.82;
    margin: 0;
    text-transform: uppercase;
  }

  h1 span {
    display: block;
    color: transparent;
    -webkit-text-stroke: 2px #2cf7e7;
  }

  h1 strong {
    display: block;
    color: #2cf7e7;
    text-shadow: 0 0 35px rgba(44, 247, 231, 0.8);
  }

  .hero-text {
    max-width: 720px;
    margin: 1.5rem auto;
    font-size: 1.15rem;
    color: #d8f0ef;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #2cf7e7;
    color: #001111;
    padding: 1rem 1.6rem;
    border-radius: 999px;
    font-weight: 900;
    text-decoration: none;
    box-shadow: 0 0 25px rgba(44, 247, 231, 0.35);
    transition: 0.2s ease;
  }

  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 0 40px rgba(44, 247, 231, 0.6);
  }

  .big {
    font-size: 1.05rem;
    padding: 1.15rem 2rem;
  }

  .limited {
    color: #2cf7e7;
    font-weight: 800;
  }

  h2 {
    text-align: center;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 1;
    margin: 0 0 3rem;
    text-transform: uppercase;
  }

  .grid {
    display: grid;
    gap: 1.2rem;
  }

  .cards {
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .cards article,
  .reviews article {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(44, 247, 231, 0.14);
    padding: 2rem;
    border-radius: 24px;
    backdrop-filter: blur(12px);
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.22);
  }

  .cards span {
    font-size: 2rem;
  }

  .cards h3 {
    margin: 0.8rem 0;
    color: #2cf7e7;
  }

  .cards p,
  .reviews p {
    color: #d7eceb;
  }

  .includes {
    position: relative;
  }

  .includes::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, rgba(44, 247, 231, 0.09), transparent 55%);
    pointer-events: none;
  }

  .includes .container {
    position: relative;
    z-index: 1;
  }

  .includes-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.15rem;
  }

  .include-card {
    position: relative;
    min-height: 210px;
    padding: 1.6rem;
    border-radius: 26px;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.025));
    border: 1px solid rgba(44, 247, 231, 0.22);
    box-shadow:
      inset 0 0 28px rgba(44, 247, 231, 0.045),
      0 18px 45px rgba(0, 0, 0, 0.25);
    transition:
      transform 0.22s ease,
      border-color 0.22s ease,
      box-shadow 0.22s ease;
  }

  .include-card::before {
    content: "";
    position: absolute;
    inset: -1px;
    background: linear-gradient(
      135deg,
      rgba(44, 247, 231, 0.45),
      transparent 38%,
      rgba(44, 247, 231, 0.15)
    );
    opacity: 0;
    transition: opacity 0.22s ease;
    pointer-events: none;
  }

  .include-card::after {
    content: "";
    position: absolute;
    width: 120px;
    height: 120px;
    right: -45px;
    bottom: -45px;
    border-radius: 999px;
    background: rgba(44, 247, 231, 0.12);
    filter: blur(4px);
  }

  .include-card:hover {
    transform: translateY(-8px);
    border-color: rgba(44, 247, 231, 0.55);
    box-shadow:
      0 0 34px rgba(44, 247, 231, 0.18),
      0 24px 60px rgba(0, 0, 0, 0.38);
  }

  .include-card:hover::before {
    opacity: 1;
  }

  .include-icon {
    position: relative;
    z-index: 1;
    display: grid;
    place-items: center;
    width: 58px;
    height: 58px;
    margin-bottom: 1.2rem;
    border-radius: 18px;
    background: rgba(44, 247, 231, 0.12);
    border: 1px solid rgba(44, 247, 231, 0.28);
    font-size: 1.8rem;
    box-shadow: 0 0 22px rgba(44, 247, 231, 0.12);
  }

  .include-card h3 {
    position: relative;
    z-index: 1;
    margin: 0 0 0.6rem;
    color: #ffffff;
    font-size: 1.05rem;
    line-height: 1.2;
  }

  .include-card p {
    position: relative;
    z-index: 1;
    margin: 0;
    color: #b9d7d6;
    line-height: 1.55;
    font-size: 0.95rem;
  }

  .reviews {
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .reviews article {
    text-align: center;
  }

  .reviews img {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    object-fit: cover;
    margin: auto auto 1rem;
    border: 3px solid #2cf7e7;
  }

  .reviews p {
    font-style: italic;
  }

  .reviews strong {
    display: block;
    margin-top: 1rem;
    color: #2cf7e7;
  }

  .cta {
    text-align: center;
    padding-bottom: 7rem;
  }

  .cta p {
    max-width: 700px;
    margin: -1rem auto 2rem;
    color: #d7eceb;
  }

  @media (max-width: 980px) {
    .includes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: 6rem 0;
    }

    h1 {
      font-size: clamp(4rem, 22vw, 7rem);
    }

    .hero-text {
      font-size: 1rem;
    }
  }

  @media (max-width: 560px) {
    .includes-grid {
      grid-template-columns: 1fr;
    }

    .include-card {
      min-height: auto;
    }
  }

  .countdown {
  width: min(520px, 100%);
  margin: 2.4rem auto 0;
  padding: 1.2rem;
  border: 1px solid rgba(44, 247, 231, 0.22);
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.045);
  box-shadow:
    inset 0 0 28px rgba(44, 247, 231, 0.045),
    0 18px 45px rgba(0, 0, 0, 0.22);
  backdrop-filter: blur(12px);
}

.countdown-label {
  margin: 0 0 1rem;
  color: #2cf7e7;
  font-size: 0.9rem;
  font-weight: 900;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-align: center;
}

.countdown-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.8rem;
}

.countdown-grid div {
  padding: 0.9rem 0.5rem;
  border-radius: 18px;
  background: rgba(44, 247, 231, 0.08);
  border: 1px solid rgba(44, 247, 231, 0.16);
  text-align: center;
}

.countdown-grid strong {
  display: block;
  color: #ffffff;
  font-size: clamp(1.9rem, 4vw, 2.7rem);
  line-height: 1;
  text-shadow: 0 0 18px rgba(44, 247, 231, 0.4);
}

.countdown-grid span {
  display: block;
  margin-top: 0.4rem;
  color: #b9d7d6;
  font-size: 0.75rem;
  font-weight: 800;
  text-transform: uppercase;
}
</style>